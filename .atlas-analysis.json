  "keyFeatures": [
    "Three-stage finite state machine (Registering → Voting → Resetting)",
    "Entry fee mechanism to prevent sybil attacks",
    "Real-time vote counting and winner determination",
    "Secure admin controls with onlyOwner access pattern",
    "Prize pool management with sweep functionality",
    "Wallet integration via RainbowKit and Wagmi",
    "Comprehensive test coverage with Vitest and Foundry"
  ],
  "publicApiSurface": [
    "useMemberVote() - Main React hook for contract interaction",
    "castVote(option: number) - Submit a vote with entry fee",
    "startVote() - Admin function to open polls",
    "resetVotes() - Admin function to close voting and tally results",
    "withdrawFunds() - Admin function to collect entry fees",
    "getWorkflowStation() - Query current election state",
    "getOptionAVotes() - Query votes for Option A",
    "getOptionBVotes() - Query votes for Option B",
    "getOwner() - Query contract owner address",
    "addressVoted(voter: address) - Check if address has voted",
    "AdminPanel - Admin control component",
    "VotingCard - Voting interface component",
    "DashboardGrid - Results display component"
  ]
}
